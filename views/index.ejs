<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/stylesheets/style.css">

  <style>
    /* layout visibility guide */
    nav, header, main, footer, .container {
      outline: 1px solid rgba(255, 0, 0, 0.25);
      outline-offset: 6px;
    }
  </style>

</head>
<body>
  <!-- Main Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark custom-nav">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/marketplace?section=marketplace">CougPlace</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navMenu">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link <%= section === 'marketplace' || section === 'search-results' || section === 'item-details' ? 'active' : '' %>" href="/marketplace?section=marketplace">
              Marketplace
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= section === 'profile' || section === 'edit-profile' || section === 'change-password' ? 'active' : '' %>" href="/marketplace?section=profile">
              Profile
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= section === 'seller-dashboard' || section === 'create-listing' || section === 'seller-messages' || section === 'report-listing' || section === 'become-seller' ? 'active' : '' %>" href="/marketplace?section=seller-dashboard">
              Seller
            </a>
          </li>
          <% if (currentUser && currentUser.email === "admin@wsu.edu") { %>
          <li class="nav-item">
            <a class="nav-link text-warning fw-bold" href="/admin/dashboard">
              Admin Dashboard
            </a>
          </li>
          <% } %>
          <li class="nav-item">
            <a class="nav-link text-warning fw-bold" href="/logout">
              Sign Out
            </a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Marketplace family subnav -->
  <% if (section === 'marketplace' || section === 'search-results' || section === 'item-details') { %>
    <div class="container mt-4">
      <div class="d-flex gap-2 flex-wrap mb-4">
        <a href="/marketplace?section=marketplace" class="btn btn-outline-dark">Marketplace</a>
        <a href="/marketplace?section=search-results" class="btn btn-outline-dark">Search Results</a>
        <a href="/marketplace?section=item-details" class="btn btn-outline-dark">Item Details</a>
      </div>
    </div>
  <% } %>

  <!-- Profile family subnav -->
  <% if (section === 'profile' || section === 'edit-profile' || section === 'change-password') { %>
    <div class="container mt-4">
      <div class="d-flex gap-2 flex-wrap mb-4">
        <a href="/marketplace?section=profile" class="btn btn-outline-dark">Profile</a>
        <a href="/marketplace?section=edit-profile" class="btn btn-outline-dark">Edit Profile</a>
        <a href="/marketplace?section=change-password" class="btn btn-outline-dark">Change Password</a>
      </div>
    </div>
  <% } %>

  <!-- Seller family subnav -->
  <% if (section === 'seller-dashboard' || section === 'create-listing' || section === 'seller-messages' || section === 'report-listing' || section === 'become-seller') { %>
    <div class="container mt-4">
      <div class="d-flex gap-2 flex-wrap mb-4">
        <a href="/marketplace?section=seller-dashboard" class="btn btn-outline-dark">Seller Dashboard</a>
        <a href="/marketplace?section=create-listing" class="btn btn-outline-dark">Create Listing</a>
        <a href="/marketplace?section=seller-messages" class="btn btn-outline-dark">Messages</a>
        <a href="/marketplace?section=report-listing" class="btn btn-outline-dark">Report Listing</a>
        <a href="/marketplace?section=become-seller" class="btn btn-outline-dark">Become Seller</a>
      </div>
    </div>
  <% } %>

  <% if (section === 'marketplace') { %>
    <header class="hero-section py-5">
      <div class="container text-center">
        <h1 class="fw-bold">Buy and Sell on Campus</h1>
        <p class="lead">Find textbooks, electronics, dorm supplies, and more from verified students.</p>

        <form class="row justify-content-center g-2 mt-3" action="/marketplace" method="GET">
          <input type="hidden" name="section" value="search-results">
          <div class="col-md-6">
            <input type="text" name="q" class="form-control" placeholder="Search for textbooks, calculators, mini fridges..." value="<%= q || '' %>">
          </div>
          <div class="col-md-2">
            <button class="btn btn-light w-100" type="submit">Search</button>
          </div>
        </form>
      </div>
    </header>

    <main class="container my-5">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="section-title mb-0">Latest Listings</h2>
        <select class="form-select w-auto" disabled>
          <option selected>All Categories</option>
          <option>Textbooks</option>
          <option>Electronics</option>
          <option>Dorm Supplies</option>
          <option>School Supplies</option>
        </select>
      </div>

      <div class="row g-4">
        <% if (!listings || listings.length === 0) { %>
          <div class="col-12">
            <div class="alert alert-secondary mb-0">No active listings yet.</div>
          </div>
        <% } %>

        <% listings.forEach(function(listing) { %>
          <div class="col-md-4">
            <div class="card listing-card h-100">
              <img src="<%= listing.image %>" class="card-img-top" alt="<%= listing.title %>">
              <div class="card-body">
                <h5 class="card-title"><%= listing.title %></h5>
                <p class="card-text text-muted"><%= listing.description %></p>
                <p class="price">$<%= listing.price %></p>
                <a href="/marketplace?section=item-details&id=<%= listing.id %>" class="btn btn-primary-custom">View Details</a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </main>

    <footer class="py-4 text-center footer-custom">
      <div class="container">
        <p class="mb-0">© 2026 CougPlace - Campus Marketplace for Students</p>
      </div>
    </footer>

    <% } else if (section === 'search-results') { %>
    <main class="container my-5">
      <div class="mb-4">
        <h1 class="fw-bold">Search Results</h1>
        <p class="text-muted">
          Showing results for:
          <strong><%= q || 'all listings' %></strong>
          <% if (category) { %>
            in <strong><%= category %></strong>
          <% } %>
        </p>
      </div>

      <form class="row mb-4 g-3" action="/marketplace" method="GET">
        <input type="hidden" name="section" value="search-results">

        <div class="col-md-4">
          <input
            type="text"
            name="q"
            class="form-control"
            value="<%= q || '' %>"
            placeholder="Search listings"
          >
        </div>

        <div class="col-md-3">
          <select name="category" class="form-select">
            <option value="">All Categories</option>
            <option value="Books" <%= category === 'Books' ? 'selected' : '' %>>Books</option>
            <option value="Electronics" <%= category === 'Electronics' ? 'selected' : '' %>>Electronics</option>
            <option value="School Supplies" <%= category === 'School Supplies' ? 'selected' : '' %>>School Supplies</option>
            <option value="Dorm Supplies" <%= category === 'Dorm Supplies' ? 'selected' : '' %>>Dorm Supplies</option>
            <option value="Other" <%= category === 'Other' ? 'selected' : '' %>>Other</option>
          </select>
        </div>

        <div class="col-md-3">
          <select name="sort" class="form-select">
            <option value="">Sort By</option>
            <option value="priceLow" <%= sort === 'priceLow' ? 'selected' : '' %>>Price Low to High</option>
            <option value="priceHigh" <%= sort === 'priceHigh' ? 'selected' : '' %>>Price High to Low</option>
            <option value="titleAZ" <%= sort === 'titleAZ' ? 'selected' : '' %>>Title A to Z</option>
            <option value="titleZA" <%= sort === 'titleZA' ? 'selected' : '' %>>Title Z to A</option>
          </select>
        </div>

        <div class="col-md-2">
          <button class="btn btn-primary-custom w-100" type="submit">Apply</button>
        </div>
      </form>

      <div class="row g-4">
        <% if (!filteredListings || filteredListings.length === 0) { %>
          <div class="col-12">
            <div class="alert alert-secondary">No listings matched your search.</div>
          </div>
        <% } %>

        <% filteredListings.forEach(function(listing) { %>
          <div class="col-md-6">
            <div class="card listing-card h-100">
              <div class="row g-0">
                <div class="col-md-4">
                  <img src="<%= listing.image %>" class="img-fluid rounded-start h-100 object-fit-cover" alt="<%= listing.title %>">
                </div>
                <div class="col-md-8">
                  <div class="card-body">
                    <h5 class="card-title"><%= listing.title %></h5>
                    <p class="card-text text-muted"><%= listing.description %></p>
                    <p class="price">$<%= listing.price %></p>
                    <a href="/marketplace?section=item-details&id=<%= listing.id %>" class="btn btn-primary-custom">View Details</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </main>

  <% } else if (section === 'item-details') { %>
    <main class="container my-5">
      <% if (!selectedListing) { %>
        <div class="alert alert-warning">Listing not found.</div>
      <% } else { %>
        <div class="row g-5">
          <div class="col-lg-6">
            <img src="<%= selectedListing.image %>" class="img-fluid rounded shadow-sm" alt="<%= selectedListing.title %>">
          </div>

          <div class="col-lg-6">
            <h1 class="fw-bold"><%= selectedListing.title %></h1>
            <p class="price-lg">$<%= selectedListing.price %></p>
            <p class="text-muted">Category: <%= selectedListing.category %></p>

            <div class="mb-4">
              <h5>Description</h5>
              <p><%= selectedListing.description %></p>
            </div>

            <div class="mb-4">
              <h5>Seller Information</h5>
              <p class="mb-1"><strong>Name:</strong> <%= selectedListing.sellerName %></p>
              <p class="mb-1"><strong>Email:</strong> <%= selectedListing.sellerEmail %></p>
              <p class="mb-0"><strong>Pickup Area:</strong> <%= selectedListing.pickupArea %></p>
            </div>

            <div class="d-flex gap-2">
              <a href="/marketplace?section=report-listing&id=<%= selectedListing.id %>" class="btn btn-outline-danger">Report Listing</a>
              <a href="/marketplace?section=marketplace" class="btn btn-primary-custom">Back to Marketplace</a>
            </div>
          </div>
        </div>
      <% } %>
    </main>

  <% } else if (section === 'profile') { %>
    <main class="container my-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card shadow-sm border-0 profile-card">
            <div class="card-body p-4">
              <div class="d-flex align-items-center gap-4 flex-wrap">
                <img src="https://via.placeholder.com/120" class="rounded-circle profile-img" alt="Profile Picture">
                <h2 class="fw-bold mb-1">
                  <%= currentUser ? currentUser.firstName + ' ' + currentUser.lastName : 'Unknown User' %>
                </h2>
                <p class="text-muted mb-1">Verified WSU Student</p>
                <p class="mb-0"><%= currentUser ? currentUser.email : 'No email available' %></p>
                </div>
              </div>

              <hr class="my-4">

              <div class="row g-3">
                <div class="col-md-6">
                  <h6 class="text-muted">Gender</h6>
                  <p><%= currentUser ? currentUser.gender : 'Not provided' %></p>
                </div>
                <div class="col-md-6">
                  <h6 class="text-muted">Age</h6>
                  <p><%= currentUser ? currentUser.age : 'Not provided' %></p>
                </div>
                <div class="col-12">
                  <h6 class="text-muted">Bio</h6>
                  <p>
                    <% if (currentUser) { %>
                      <%= currentUser.firstName %> is using CougPlace to buy and sell items on campus.
                    <% } else { %>
                      No bio available.
                    <% } %>
                  </p>
                </div>
              </div>

              <div class="mt-4 d-flex gap-2">
                <a href="/marketplace?section=edit-profile" class="btn btn-primary-custom">Edit Profile</a>
                <a href="/marketplace?section=change-password" class="btn btn-outline-secondary">Change Password</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <footer class="py-4 text-center footer-custom">
      <div class="container">
        <p class="mb-0">© 2026 CougPlace</p>
      </div>
    </footer>

  <% } else if (section === 'edit-profile') { %>
  <main class="container my-5">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="card shadow-sm border-0 profile-card">
          <div class="card-body p-4">
            <h2 class="fw-bold mb-4">Edit Profile</h2>

            <form>
              <div class="mb-3">
                <label class="form-label">First Name</label>
                <input
                  type="text"
                  class="form-control"
                  value="<%= currentUser ? currentUser.firstName : '' %>"
                >
              </div>

              <div class="mb-3">
                <label class="form-label">Last Name</label>
                <input
                  type="text"
                  class="form-control"
                  value="<%= currentUser ? currentUser.lastName : '' %>"
                >
              </div>

              <div class="mb-3">
                <label class="form-label">Email</label>
                <input
                  type="email"
                  class="form-control"
                  value="<%= currentUser ? currentUser.email : '' %>"
                >
              </div>

              <div class="mb-3">
                <label class="form-label">Gender</label>
                <select class="form-select">
                  <option <%= currentUser && currentUser.gender === 'Male' ? 'selected' : '' %>>
                    Male
                  </option>
                  <option <%= currentUser && currentUser.gender === 'Female' ? 'selected' : '' %>>
                    Female
                  </option>
                  <option <%= currentUser && currentUser.gender === 'Other' ? 'selected' : '' %>>
                    Other
                  </option>
                </select>
              </div>

              <div class="mb-3">
                <label class="form-label">Age</label>
                <input
                  type="number"
                  class="form-control"
                  value="<%= currentUser ? currentUser.age : '' %>"
                >
              </div>

              <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary-custom">
                  Save Changes
                </button>
                <a
                  href="/marketplace?section=profile"
                  class="btn btn-outline-secondary"
                >
                  Cancel
                </a>
              </div>
            </form>

          </div>
        </div>
      </div>
    </div>
  </main>

  <% } else if (section === 'change-password') { %>
  <main class="container my-5">
    <div class="row justify-content-center">
      <div class="col-lg-6">
        <div class="card shadow-sm border-0">
          <div class="card-body p-4">
            <h2 class="fw-bold mb-4">Change Password</h2>

            <% if (error) { %>
              <div class="alert alert-danger">
                <%= error %>
              </div>
            <% } %>

            <% if (success) { %>
              <div class="alert alert-success">
                <%= success %>
              </div>
            <% } %>

            <form action="/marketplace/change-password" method="POST">
              <div class="mb-3">
                <label class="form-label">Current Password</label>
                <input
                  type="password"
                  name="currentPassword"
                  class="form-control"
                  required
                >
              </div>

              <div class="mb-3">
                <label class="form-label">New Password</label>
                <input
                  type="password"
                  name="newPassword"
                  class="form-control"
                  required
                >
              </div>

              <div class="mb-3">
                <label class="form-label">Confirm New Password</label>
                <input
                  type="password"
                  name="confirmPassword"
                  class="form-control"
                  required
                >
              </div>

              <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary-custom">
                  Update Password
                </button>
                <a
                  href="/marketplace?section=profile"
                  class="btn btn-outline-secondary"
                >
                  Cancel
                </a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </main>

  <% } else if (section === 'seller-dashboard') { %>
    <main class="container my-5">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h2 class="fw-bold mb-1">Seller Dashboard</h2>
          <p class="text-muted mb-0">Manage your active, sold, and draft listings.</p>
        </div>
        <a href="/marketplace?section=create-listing" class="btn btn-primary-custom">Create Listing</a>
      </div>

      <div class="row g-4 mb-4">
        <div class="col-md-4">
          <div class="card shadow-sm border-0">
            <div class="card-body text-center">
              <h5 class="fw-bold"><%= activeCount %></h5>
              <p class="text-muted mb-0">Active Listings</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card shadow-sm border-0">
            <div class="card-body text-center">
              <h5 class="fw-bold"><%= soldCount %></h5>
              <p class="text-muted mb-0">Sold Items</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card shadow-sm border-0">
            <div class="card-body text-center">
              <h5 class="fw-bold"><%= draftCount %></h5>
              <p class="text-muted mb-0">Draft Listings</p>
            </div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0">My Listings</h4>
          </div>

          <div class="table-responsive">
            <table class="table align-middle">
              <thead>
                <tr>
                  <th>Item</th>
                  <th>Category</th>
                  <th>Price</th>
                  <th>Status</th>
                  <th>Pickup Area</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (!sellerListings || sellerListings.length === 0) { %>
                  <tr>
                    <td colspan="6" class="text-center text-muted">No listings yet.</td>
                  </tr>
                <% } %>

                <% sellerListings.forEach(function(listing) { %>
                  <tr>
                    <td><%= listing.title %></td>
                    <td><%= listing.category %></td>
                    <td>$<%= listing.price %></td>
                    <td>
                      <% if (listing.status === 'Active') { %>
                        <span class="badge text-bg-success">Active</span>
                      <% } else if (listing.status === 'Sold') { %>
                        <span class="badge text-bg-secondary">Sold</span>
                      <% } else { %>
                        <span class="badge text-bg-warning">Draft</span>
                      <% } %>
                    </td>
                    <td><%= listing.pickupArea %></td>
                    <td class="text-end">
                      <a href="/marketplace?section=item-details&id=<%= listing.id %>" class="btn btn-sm btn-outline-secondary">View</a>

                      <% if (listing.status !== 'Sold') { %>
                        <form action="/marketplace/listings/<%= listing.id %>/sold" method="POST" style="display:inline;">
                          <button class="btn btn-sm btn-primary-custom" type="submit">Mark as Sold</button>
                        </form>
                      <% } %>

                      <form action="/marketplace/listings/<%= listing.id %>/delete" method="POST" style="display:inline;">
                        <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card shadow-sm border-0">
        <div class="card-body">
          <h4 class="fw-bold mb-3">Recent Seller Activity</h4>
          <ul class="list-group list-group-flush">
            <li class="list-group-item">Create a new listing to see it appear in your dashboard.</li>
            <li class="list-group-item">Active, sold, and draft counts update automatically.</li>
            <li class="list-group-item">Use the buttons above to view, sell, or delete listings.</li>
          </ul>
        </div>
      </div>
    </main>

  <% } else if (section === 'create-listing') { %>
    <main class="container my-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card shadow-sm border-0">
            <div class="card-body p-4">
              <h2 class="fw-bold mb-4">Create New Listing</h2>

              <form action="/marketplace/listings" method="POST">
                <div class="mb-3">
                  <label class="form-label">Item Title</label>
                  <input type="text" name="title" class="form-control" placeholder="Ex: TI-84 Calculator" required>
                </div>

                <div class="mb-3">
                  <label class="form-label">Description</label>
                  <textarea name="description" class="form-control" rows="4" placeholder="Describe the condition and details of the item" required></textarea>
                </div>

                <div class="row">
                  <div class="col-md-6 mb-3">
                    <label class="form-label">Category</label>
                    <select name="category" class="form-select" required>
                      <option value="">Select a category</option>
                      <option>Books</option>
                      <option>Electronics</option>
                      <option>School Supplies</option>
                      <option>Dorm Supplies</option>
                      <option>Other</option>
                    </select>
                  </div>

                  <div class="col-md-6 mb-3">
                    <label class="form-label">Price</label>
                    <input type="number" name="price" class="form-control" placeholder="Ex: 70" required>
                  </div>
                </div>

                <div class="mb-3">
                  <label class="form-label">Pickup Area</label>
                  <input type="text" name="pickupArea" class="form-control" placeholder="Ex: CUB, Library, Dorm Lobby" required>
                </div>

                <div class="mb-3">
                  <label class="form-label">Image URL</label>
                  <input type="text" name="image" class="form-control" placeholder="Paste image URL or leave blank for placeholder">
                </div>

                <div class="mb-3">
                  <label class="form-label">Listing Status</label>
                  <select name="status" class="form-select">
                    <option value="Active">Publish Now</option>
                    <option value="Draft">Save as Draft</option>
                  </select>
                </div>

                <div class="d-flex gap-2 mt-4">
                  <button type="submit" class="btn btn-primary-custom">Post Listing</button>
                  <a href="/marketplace?section=seller-dashboard" class="btn btn-outline-secondary">Go to Dashboard</a>
                  <a href="/marketplace?section=seller-dashboard" class="btn btn-outline-danger">Cancel</a>
                </div>
              </form>

            </div>
          </div>
        </div>
      </div>
    </main>

  <% } else if (section === 'seller-messages') { %>
    <main class="container my-5">
      <h2 class="fw-bold mb-4">Seller Messages</h2>

      <div class="row g-4">
        <div class="col-lg-4">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
              <h5 class="fw-bold mb-3">Conversations</h5>

              <div class="list-group">
                <a href="#" class="list-group-item list-group-item-action active">
                  Alex Johnson - TI-84 Calculator
                </a>
                <a href="#" class="list-group-item list-group-item-action">
                  Maya Lee - Biology Textbook
                </a>
                <a href="#" class="list-group-item list-group-item-action">
                  Jordan Kim - Lab Coat
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="col-lg-8">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex flex-column">
              <div class="border-bottom pb-3 mb-3">
                <h5 class="fw-bold mb-1">Alex Johnson</h5>
                <p class="text-muted mb-0">About: TI-84 Calculator</p>
              </div>

              <div class="flex-grow-1 mb-3">
                <div class="mb-3">
                  <div class="p-3 bg-light rounded">
                    <strong>Alex:</strong> Hi, is this calculator still available?
                  </div>
                </div>

                <div class="mb-3 text-end">
                  <div class="p-3 rounded d-inline-block border">
                    <strong>You:</strong> Yes, it is still available.
                  </div>
                </div>

                <div class="mb-3">
                  <div class="p-3 bg-light rounded">
                    <strong>Alex:</strong> Could we meet at the library tomorrow around 2?
                  </div>
                </div>
              </div>

              <form>
                <label class="form-label">Reply</label>
                <textarea class="form-control mb-3" rows="3" placeholder="Type your response here"></textarea>
                <div class="d-flex gap-2">
                  <button type="submit" class="btn btn-primary-custom">Send Message</button>
                  <button type="button" class="btn btn-outline-secondary">Send Pickup Details</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </main>

  <% } else if (section === 'report-listing') { %>
    <main class="container my-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card shadow-sm border-0">
            <div class="card-body p-4">
              <h1 class="fw-bold mb-3">Report Listing</h1>
              <p class="text-muted">
                Use this form to report suspicious, misleading, or inappropriate listings.
              </p>

              <form action="/marketplace/report" method="POST">
                <div class="mb-3">
                  <label for="listingName" class="form-label">Listing</label>
                  <input
                    type="text"
                    class="form-control"
                    id="listingName"
                    name="Listing"
                    value="<%= selectedListing ? selectedListing.title : 'Unknown Listing' %>"
                    readonly
                  >
                </div>

                <div class="mb-3">
                  <label for="reason" class="form-label">Reason for Report</label>
                  <select class="form-select" id="reason" name="reason">
                    <option selected>Select a reason</option>
                    <option>Inappropriate content</option>
                    <option>Spam or scam</option>
                    <option>Misleading description</option>
                    <option>Prohibited item</option>
                    <option>Other</option>
                  </select>
                </div>

                <div class="mb-3">
                  <label for="details" class="form-label">Additional Details</label>
                  <textarea class="form-control" id="details" name="details" rows="5" placeholder="Provide more details here..."></textarea>
                </div>

                <div class="d-flex gap-2">
                  <button type="submit" class="btn btn-danger">Submit Report</button>
                  <a href="/marketplace?section=item-details<%= selectedListing ? '&id=' + selectedListing.id : '' %>" class="btn btn-outline-secondary">Cancel</a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </main>

  <% } else if (section === 'become-seller') { %>
    <main class="container my-5">
      <div class="row justify-content-center">
        <div class="col-lg-7">
          <div class="card shadow-sm border-0">
            <div class="card-body p-4">
              <h2 class="fw-bold mb-3">Create Seller Profile</h2>
              <p class="text-muted mb-4">
                Activate your seller account to start posting listings and managing sales on CougPlace.
              </p>

              <form>
                <div class="mb-3">
                  <label class="form-label">Full Name</label>
                  <input type="text" class="form-control" placeholder="Enter your full name">
                </div>

                <div class="mb-3">
                  <label class="form-label">WSU Email</label>
                  <input type="email" class="form-control" placeholder="yourname@wsu.edu">
                </div>

                <div class="mb-3">
                  <label class="form-label">Preferred Pickup Area</label>
                  <input type="text" class="form-control" placeholder="Ex: CUB, Library, Spark">
                </div>

                <div class="mb-3">
                  <label class="form-label">Seller Bio</label>
                  <textarea class="form-control" rows="3" placeholder="Optional short seller description"></textarea>
                </div>

                <div class="form-check mb-4">
                  <input class="form-check-input" type="checkbox" id="rulesCheck">
                  <label class="form-check-label" for="rulesCheck">
                    I agree to follow CougPlace marketplace rules and campus safety guidelines.
                  </label>
                </div>

                <div class="d-flex gap-2">
                  <button type="submit" class="btn btn-primary-custom">Create Seller Profile</button>
                  <button type="button" class="btn btn-outline-secondary">Save for Later</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </main>
  <% } %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
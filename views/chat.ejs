<!DOCTYPE html>
<html>
<head>
  <title>CougPlace Chat</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>

  <nav class="navbar navbar-expand-lg navbar-dark custom-nav">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/marketplace?section=marketplace">CougPlace</a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navMenu">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/marketplace?section=marketplace">Marketplace</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/marketplace?section=seller-dashboard">Seller</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="/chat">Chat</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container my-5">

    <h2 class="fw-bold mb-4">CougPlace Chat</h2>

    <div class="card shadow-sm mb-3">
      <div class="card-body" style="height: 400px; overflow-y: auto;" id="messages"></div>
    </div>

    <div class="input-group">
      <input id="msg" type="text" class="form-control" placeholder="Type a message...">
      <button class="btn btn-primary" onclick="send()">Send</button>
    </div>

  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();
    const messages = document.getElementById('messages');

    socket.on('chatMessage', function(msg) {
      const div = document.createElement('div');
      div.className = "mb-2";
      div.textContent = msg;
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
    });

    function send() {
      const input = document.getElementById('msg');
      const msg = input.value;

      if (!msg.trim()) return;

      socket.emit('chatMessage', msg);
      input.value = '';
    }
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
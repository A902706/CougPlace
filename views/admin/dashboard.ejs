<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        
        .cougplaceRed
        {
            background-color: #981e32 !important;
            border-color: #981e32 !important;
            color: white !important; 
        }

        .cougplaceRed:hover{
            background-color: #7f182a !important;
            border-color: #7f182a !important;
        }
    </style>
</head>
<body>

<nav class="navbar navbar-dark cougplaceRed mb-4">
    <div class="container-fluid">
        <a class="navbar-brand" href="/admin/dashboard">CougPlace</a>
        <a class="nav-link text-white" href="/marketplace">Go to CougPlace</a>
    </div>
</nav>

<div class="container">
    <h1 class="mb-3">Welcome <%= currentUser.firstName %>,</h1>

    <div class="row row-cols-1 row-cols-md-3 g-3">

        <div class="col"><div class="card"><div class="card-body">
            <h5>Manage Users</h5>
            <a href="/admin/users" class="btn btn-primary">Click</a>
        </div></div></div>

        <div class="col"><div class="card"><div class="card-body">
            <h5>Manage Content</h5>
            <a href="/admin/content" class="btn btn-primary">Click</a>
        </div></div></div>

        <div class="col"><div class="card"><div class="card-body">
            <h5>Message Moderation</h5>
            <a href="/admin/messages" class="btn btn-primary">Click</a>
        </div></div></div>

        <div class="col"><div class="card"><div class="card-body">
            <h5>Suspicious Activity</h5>
            <a href="/admin/suspicious" class="btn btn-primary">Click</a>
        </div></div></div>

        <div class="col"><div class="card"><div class="card-body">
            <h5>Categories</h5>
            <a href="/admin/categories" class="btn btn-primary">Click</a>
        </div></div></div>

        <div class="col"><div class="card"><div class="card-body">
            <h5>Announcements</h5>
            <a href="/admin/announcements" class="btn btn-primary">Click</a>
        </div></div></div>

        <div class="col"><div class="card"><div class="card-body">
            <h5>Tickets</h5>
            <a href="/admin/tickets" class="btn btn-primary">Click</a>
        </div></div></div>

    </div>
</div>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Message Moderation - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .cougplaceRed
        {
            background-color: #981e32 !important;
            border-color: #981e32 !important;
            color: white !important; 
        }

        .cougplaceRed:hover{
            background-color: #7f182a !important;
            border-color: #7f182a !important;
        }
    </style>
</head>
<body>
    <!-- Navbar says website name and links to dashboard-->
    <nav class="navbar navbar-expand-lg navbar-dark cougplaceRed mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">CougPlace</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/admin/dashboard">Dashboard</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container">
        <h1 class="mb-3">Message Moderation</h1>
        <p class="lead">Review reported or flagged chat messages and take appropriate action.</p>

        <!-- Messages Table -->
        <table class="table table-hover table-striped">
            <thead class="table-dark"><!-- Table header with the names for each column -->
                <tr>
                    <th scope="col">Message ID</th>
                    <th scope="col">Sender</th>
                    <th scope="col">Recipient</th>
                    <th scope="col">Message Content</th>
                    <th scope="col">Reported Reason</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody><!-- Table body with example messages that could have been reported  -->
                <tr>
                    <td>101</td>
                    <td>Andres1</td>
                    <td>Andres2</td>
                    <td>Where do you live?</td>
                    <td>Suspicious message</td>
                    <td>
                        <button class="btn btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#actionModal" data-action="Clear" data-message="101">Mark as Safe</button>
                        <button class="btn btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#actionModal" data-action="Warn" data-message="101">Warn Sender</button>
                        <button class="btn btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#actionModal" data-action="Delete" data-message="101">Delete Message</button>
                    </td>
                </tr>
                <tr>
                    <td>102</td>
                    <td>Andres2</td>
                    <td>Andres1</td>
                    <td>This is an offensive message!</td>
                    <td>Harassment</td>
                    <td>
                        <button class="btn btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#actionModal" data-action="Clear" data-message="102">Mark as Safe</button>
                        <button class="btn btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#actionModal" data-action="Warn" data-message="102">Warn Sender</button>
                        <button class="btn btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#actionModal" data-action="Delete" data-message="102">Delete Message</button>
                    </td>
                </tr>
                <!-- More rows will be done dynamically later with js-->
            </tbody>
        </table>
    </div>

    <!-- Modal Which will as if the admin wants to do ___ action on the text -->
    <div class="modal fade" id="actionModal" tabindex="-1" aria-labelledby="actionModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="actionModalLabel">Confirm Action</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to perform this action on the message?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary">Confirm</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    </script>
</body>
</html>